#!/usr/bin/env bash

set -euo pipefail

pid_file="/tmp/open-daily-note.pid"
server_file="/tmp/open-daily-note.sock"
notes_dir="/home/ant/obsidian/300 Daily Notes"
template_path="/home/ant/obsidian/999 Templates/Daily Note Template.md"
note_name="$(date +%d-%m-%Y).md"
note_path="${notes_dir}/${note_name}"
previous_note_name="$(date -d yesterday +%d-%m-%Y).md"
previous_note_path="${notes_dir}/${previous_note_name}"

extract_section() {
  local source_path="$1"
  local section_name="$2"

  awk -v section_name="$section_name" '
    BEGIN {
      in_section = 0
    }
    $0 ~ "^[[:space:]]*#{2,}[[:space:]]*\\*?\\*?(\\[\\[)?" section_name "(\\]\\])?\\*?\\*?:?[[:space:]]*$" {
      in_section = 1
      next
    }
    /^[[:space:]]*#{2,}[[:space:]]+/ {
      in_section = 0
    }
    in_section {
      print
    }
  ' "$source_path"
}

render_note() {
  local template="$1"
  local destination="$2"
  local todo_block="${3-}"

  awk -v todo_block="$todo_block" '
    BEGIN {
      in_todo = 0
      inserted = 0
      todo_lines = split(todo_block, todo, /\n/)
    }
    /^[[:space:]]*#{2,}[[:space:]]*\*?\*?(\[\[)?[Tt][Oo][Dd][Oo](\]\])?\*?\*?:?[[:space:]]*$/ {
      print
      if (!inserted && todo_block != "") {
        for (i = 1; i <= todo_lines; i++) {
          print todo[i]
        }
        inserted = 1
      }
      in_todo = inserted
      next
    }
    /^[[:space:]]*#{2,}[[:space:]]+/ {
      if (in_todo) {
        in_todo = 0
      }
      print
      next
    }
    !in_todo {
      print
    }
  ' "$template" > "$destination"
}

if [[ -f "$pid_file" ]]; then
  pid="$(<"$pid_file")"
  if kill -0 "$pid" 2>/dev/null; then
    if [[ -S "$server_file" ]]; then
      nvim --server "$server_file" --remote-send '<Esc>:wq<CR>' >/dev/null 2>&1 || true
    fi
    exit 0
  fi
  rm -f "$pid_file" "$server_file"
fi

mkdir -p "$notes_dir"

if [[ ! -e "$note_path" ]]; then
  todo_block=""
  if [[ -f "$previous_note_path" ]]; then
    todo_block="$(extract_section "$previous_note_path" "[Tt]omorrow")"
  fi

  render_note "$template_path" "$note_path" "$todo_block"
fi

rm -f "$server_file"
wezterm start --always-new-process --class wezterm-daily-note -- nvim --cmd 'let g:checkbox_timestamps = 1' --listen "$server_file" "$note_path" &
echo "$!" > "$pid_file"
disown
