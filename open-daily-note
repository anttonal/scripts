#!/usr/bin/env bash

set -euo pipefail

# Toggle today's daily note in a dedicated Ghostty + Neovim instance.
# Re-running the script closes that instance by sending save-and-quit keys to
# the fixed Neovim socket instead of killing the terminal process.

lock_file="/tmp/open-daily-note.lock"
server_file="/tmp/open-daily-note.sock"
notes_dir="/home/ant/obsidian/300 Daily Notes"
template_path="/home/ant/obsidian/999 Templates/Daily Note Template.md"
note_path="${notes_dir}/$(date +%d-%m-%Y).md"

cleanup() {
  rm -f "$server_file"
}

extract_section() {
  local source_path="$1"
  local section_name="$2"

  awk -v section_name="$section_name" '
    /^[[:space:]]*##[[:space:]]+/ {
      heading = $0
      sub(/^[[:space:]]*##[[:space:]]+/, "", heading)
      sub(/[[:space:]]*$/, "", heading)
      in_section = (heading == section_name)
      next
    }
    in_section {
      print
    }
  ' "$source_path"
}

create_note() {
  local carried_todos=""
  local previous_note_path="${notes_dir}/$(date --date='yesterday' +%d-%m-%Y).md"

  [[ -e "$note_path" ]] && return

  mkdir -p "$notes_dir"

  if [[ -f "$previous_note_path" ]]; then
    carried_todos="$(extract_section "$previous_note_path" "Tomorrow:")"
  fi

  awk -v todo_block="$carried_todos" '
    BEGIN {
      todo_count = split(todo_block, todos, /\n/)
    }
    /^[[:space:]]*##[[:space:]]+/ {
      heading = $0
      sub(/^[[:space:]]*##[[:space:]]+/, "", heading)
      sub(/[[:space:]]*$/, "", heading)

      if (heading == "Today:") {
        print
        if (todo_block != "") {
          for (i = 1; i <= todo_count; i++) {
            print todos[i]
          }
          print ""
          skip = 1
        }
        next
      }

      skip = 0
      print
      next
    }
    !skip {
      print
    }
  ' "$template_path" > "$note_path"
}

close_note() {
  # Fire-and-forget: synchronous socket health checks made the hot path feel
  # slow; sending keys directly to the known socket is fast enough.
  nvim --server "$server_file" --remote-send '<Esc>:silent! noautocmd update | silent! qa<CR>' >/dev/null 2>&1 || true
  cleanup
}

open_note() {
  cleanup
  ghostty --class=com.mitchellh.ghostty-daily-note -e \
    nvim --cmd "let g:checkbox_timestamps = 1" --listen "$server_file" "$note_path" \
    >/dev/null 2>&1 &
  disown
}

main() {
  # Drop duplicate keybind hits instead of queueing them.
  exec 9>"$lock_file"
  flock -xn 9 || return 0

  if [[ -S "$server_file" ]]; then
    close_note
    exec 9>&-
  else
    create_note
    exec 9>&-
    open_note
  fi

  rm -f "$lock_file"
}

main "$@"
