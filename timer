#!/usr/bin/env bash

set -euo pipefail

# Simple terminal countdown timer.
# Usage:
#   timer 300
#   timer -m 5
# Shows a MM:SS countdown, rings the terminal bell, and sends a notification
# when it reaches zero.

usage() {
  printf 'Usage: %s [-m] AMOUNT\n' "${0##*/}" >&2
}

main() {
  local remaining unit_multiplier=1

  # `-m` switches the numeric input from seconds to minutes.
  while getopts ':m' opt; do
    case "$opt" in
      m) unit_multiplier=60 ;;
      *) usage; return 1 ;;
    esac
  done

  shift $((OPTIND - 1))

  # Require exactly one numeric argument.
  [[ $# -eq 1 ]] || {
    usage
    return 1
  }

  [[ $1 =~ ^[0-9]+$ ]] || {
    usage
    return 1
  }

  # Store the countdown in seconds so the display/update loop stays unchanged.
  remaining=$((1 * unit_multiplier))
  remaining=$((remaining * $1))

  # Rewrite the same line each second until the countdown finishes.
  while ((remaining > 0)); do
    printf '\r%02d:%02d' $((remaining / 60)) $((remaining % 60))
    sleep 1
    ((remaining--))
  done

  # Print the final time on its own line, then ring the terminal bell.
  printf '\r00:00\n'
  printf '\a'

  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a timer "session finished, take a break"
  fi
}

main "$@"
