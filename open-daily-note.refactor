#!/usr/bin/env bash

set -euo pipefail

lock_file="/tmp/open-daily-note.lock"
server_file="/tmp/open-daily-note.sock"
notes_dir="/home/ant/obsidian/300 Daily Notes"
template_path="/home/ant/obsidian/999 Templates/Daily Note Template.md"
note_path="${notes_dir}/$(date +%d-%m-%Y).md"
previous_note_path="${notes_dir}/$(date --date='yesterday' +%d-%m-%Y).md"

cleanup() {
  rm -f "$server_file"
}

extract_section() {
  local source_path="$1"
  local section_name="$2"

  awk -v section_name="$section_name" '
    /^[[:space:]]*##[[:space:]]+/ {
      heading = $0
      sub(/^[[:space:]]*##[[:space:]]+/, "", heading)
      sub(/[[:space:]]*$/, "", heading)
      in_section = (heading == section_name)
      next
    }
    in_section {
      print
    }
  ' "$source_path"
}

create_note() {
  local carried_todos=""

  [[ -e "$note_path" ]] && return

  mkdir -p "$notes_dir"

  if [[ -f "$previous_note_path" ]]; then
    carried_todos="$(extract_section "$previous_note_path" "Tomorrow:")"
  fi

  awk -v todo_block="$carried_todos" '
    BEGIN {
      todo_count = split(todo_block, todos, /\n/)
    }
    /^[[:space:]]*##[[:space:]]+/ {
      heading = $0
      sub(/^[[:space:]]*##[[:space:]]+/, "", heading)
      sub(/[[:space:]]*$/, "", heading)

      if (heading == "Today:") {
        print
        if (todo_block != "") {
          for (i = 1; i <= todo_count; i++) {
            print todos[i]
          }
          skip = 1
        }
        next
      }

      skip = 0
      print
      next
    }
    !skip {
      print
    }
  ' "$template_path" > "$note_path"
}

close_note() {
  if [[ -S "$server_file" ]]; then
    nvim --server "$server_file" --remote-send '<Esc>:silent! noautocmd update | silent! qa<CR>' >/dev/null 2>&1 || true
  fi

  cleanup
}

open_note() {
  cleanup
  ghostty --class=com.mitchellh.ghostty-daily-note -e \
    nvim --cmd "let g:checkbox_timestamps = 1" --listen "$server_file" "$note_path" \
    >/dev/null 2>&1 &
  disown
}

main() {
  exec 9>"$lock_file"
  flock -xn 9 || return 0

  if [[ -S "$server_file" ]]; then
    close_note
    exec 9>&-
    return 0
  fi

  create_note
  exec 9>&-
  open_note
}

main "$@"
