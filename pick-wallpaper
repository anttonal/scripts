#!/usr/bin/env bash
# pick-wallpaper: pick monitor + image via rofi, apply via hyprpaper IPC.
# Requires: rofi, hyprctl, jq.

set -euo pipefail

wall_dir="$HOME/pictures/wallpaper/favorites"
cache_dir="$HOME/.cache/wallpaper"
pidfile="${XDG_RUNTIME_DIR:-/tmp}/pick-wallpaper.pid"

fail() { notify-send "Wallpaper picker" "$1"; exit 1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || fail "$1 is not available"; }

toggle_launcher() {
    [[ -f "$pidfile" ]] || return 0
    local old_pid
    old_pid=$(<"$pidfile")
    if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null \
       && [[ -r "/proc/$old_pid/comm" ]] \
       && [[ "$(<"/proc/$old_pid/comm")" == "rofi" ]]; then
        kill "$old_pid" 2>/dev/null || true
        exit 0
    fi
    rm -f "$pidfile"
}

run_rofi() {
    rofi "$@" &
    local rofi_pid=$! rc=0
    printf '%s' "$rofi_pid" > "$pidfile"
    wait "$rofi_pid" || rc=$?
    return $rc
}

pick_monitor() {
    local selection
    selection=$(
        hyprctl monitors -j | jq -r '.[] | "\(.name) (\(.model))"' \
        | run_rofi -dmenu -p "" -theme-str 'prompt {enabled: false;}'
    ) || return 1
    [[ -n "$selection" ]] || return 1
    printf '%s' "${selection%% *}"
}

pick_image() {
    local selection
    [[ -d "$wall_dir" ]] || fail "Wall dir not found: $wall_dir"
    selection=$(
        while IFS= read -r -d '' img; do
            printf '%s\0icon\x1fthumbnail://%s\n' "${img##*/}" "$img"
        done < <(find "$wall_dir" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) -print0 | sort -z) \
        | run_rofi -dmenu -show-icons -p "" -theme-str 'prompt {enabled: false;}'
    ) || return 1
    [[ -n "$selection" ]] || return 1
    printf '%s' "$wall_dir/$selection"
}

apply_wallpaper() {
    local monitor="$1" image="$2" err
    if ! err=$(hyprctl hyprpaper wallpaper "${monitor},${image}" 2>&1); then
        fail "hyprpaper failed: $err"
    fi
    mkdir -p "$cache_dir"
    ln -sf "$image" "$cache_dir/$monitor"
}

require_cmd rofi
require_cmd hyprctl
require_cmd jq

toggle_launcher
trap 'rm -f "$pidfile"' EXIT
monitor="$(pick_monitor)" || exit 0
image="$(pick_image)" || exit 0
apply_wallpaper "$monitor" "$image"
notify-send "Wallpaper picker" "${monitor}: $(basename "$image")"
