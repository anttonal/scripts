#!/usr/bin/env bash

set -euo pipefail

address="$(
    hyprctl activewindow -j 2>/dev/null |
        jq -r '.address // empty'
)"

if [[ -z "$address" ]]; then
    echo "No active Hyprland window found." >&2
    exit 1
fi

window="address:${address}"

current="$(
    hyprctl getprop "$window" opacity 2>/dev/null |
        awk 'match($0, /[0-9]+(\.[0-9]+)?/) { print substr($0, RSTART, RLENGTH); exit }'
)"

current="${current:-1.0}"

target="0.8"

if awk "BEGIN { exit !($current < 0.9) }"; then
    target="1.0"
fi

hyprctl dispatch setprop "$window" opacity "$target" lock
hyprctl dispatch setprop "$window" opacity_inactive "$target" lock
hyprctl dispatch setprop "$window" opacity_override 1 lock
hyprctl dispatch setprop "$window" opacity_inactive_override 1 lock
